#!/usr/bin/env bash

# yspace-float - Floating app/space switcher
# Uses cached data from yspace-cache for instant display

set -e

CACHE_FILE="/tmp/yspace-float-cache"
MAPPING_FILE="/tmp/yspace-float-mapping.$$"
trap "rm -f $MAPPING_FILE" EXIT

# Check if cache exists and is recent (less than 10 seconds old)
if [ -f "$CACHE_FILE" ]; then
    CACHE_AGE=$(($(date +%s) - $(stat -f %m "$CACHE_FILE")))
    if [ "$CACHE_AGE" -lt 10 ]; then
        cp "$CACHE_FILE" "$MAPPING_FILE"
    fi
fi

# If no valid cache, generate fresh (fallback)
if [ ! -s "$MAPPING_FILE" ]; then
    # Run cache script synchronously
    ~/Documents/nemo-lab.nosync/mjolnir/bin/yspace-cache
    if [ -f "$CACHE_FILE" ]; then
        cp "$CACHE_FILE" "$MAPPING_FILE"
    fi
fi

# Extract display names for the picker
FULL_LIST=$(cut -d'|' -f1 "$MAPPING_FILE" | grep -v '^$')

if [ -z "$FULL_LIST" ]; then
    echo "No apps found"
    exit 1
fi

# Show floating picker
SELECTED=$(echo "$FULL_LIST" | choose -p "Switch to app")

if [ -z "$SELECTED" ]; then
    exit 0
fi

# Find the mapping for the selected item
MAPPING=$(awk -F'|' -v sel="$SELECTED" '$1 == sel {print; exit}' "$MAPPING_FILE")
TYPE=$(echo "$MAPPING" | cut -d'|' -f2)
PARAM1=$(echo "$MAPPING" | cut -d'|' -f3)
PARAM2=$(echo "$MAPPING" | cut -d'|' -f4)

case "$TYPE" in
    iterm)
        osascript << EOF
tell application "iTerm2"
    activate
    tell window $PARAM1
        select tab $PARAM2
    end tell
end tell
EOF
        ;;
    chrome)
        osascript << EOF
tell application "Google Chrome"
    activate
    set active tab index of window $PARAM1 to $PARAM2
    set index of window $PARAM1 to 1
end tell
EOF
        ;;
    window)
        yabai -m window "$PARAM1" --focus
        ;;
    app)
        APP_NAME=$(echo "$SELECTED" | cut -d':' -f1)
        osascript -e "tell application \"$APP_NAME\" to activate"
        ;;
    *)
        APP_NAME=$(echo "$SELECTED" | cut -d':' -f1)
        osascript -e "tell application \"$APP_NAME\" to activate"
        ;;
esac

# Clear done signal if user focused on a completed item
if [[ "$SELECTED" == "✅ "* ]]; then
    SIGNAL_DIR="/tmp/mjolnir-claude-waiting"
    CLEAN_NAME="${SELECTED#✅ }"

    if [ "$TYPE" = "window" ]; then
        PROJECT_NAME="${CLEAN_NAME#*: }"
        for f in "$SIGNAL_DIR"/*; do
            [ -f "$f" ] || continue
            sig_cwd=$(jq -r '.cwd // empty' "$f" 2>/dev/null)
            sig_status=$(jq -r '.status // empty' "$f" 2>/dev/null)
            if [ "$(basename "$sig_cwd")" = "$PROJECT_NAME" ] && [ "$sig_status" = "done" ]; then
                rm -f "$f"
                break
            fi
        done
    elif [ "$TYPE" = "iterm" ]; then
        for f in "$SIGNAL_DIR"/*; do
            [ -f "$f" ] || continue
            sig_status=$(jq -r '.status // empty' "$f" 2>/dev/null)
            if [ "$sig_status" = "done" ]; then
                rm -f "$f"
                break
            fi
        done
    fi
fi
